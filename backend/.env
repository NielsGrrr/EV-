# Remplacez par votre chaîne de connexion PostgreSQL
# Exemple : postgresql://myuser:mypassword@localhost:5432/evplus_db?schema=public
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/WinaDB?schema=public"
PORT=3000

# Si vous utilisez le endpoint Socket.IO Winamax
WINAMAX_SOCKET_URL="https://sports-eu-west-3.winamax.fr/uof-sports-server"
WINAMAX_SOCKET_PATH="/socket.io"
WINAMAX_SOCKET_QUERY="language=FR&version=3.55.2&embed=false"
WINAMAX_SOCKET_ORIGIN="https://www.winamax.fr"
WINAMAX_SOCKET_REFERER="https://www.winamax.fr/"
