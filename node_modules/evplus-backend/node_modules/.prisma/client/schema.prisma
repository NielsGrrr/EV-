datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Match {
  id        String   @id @default(cuid())
  winamaxId String   @unique
  sport     String
  homeTeam  String
  awayTeam  String
  startAt   DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  odds      Odds[]
}

model Odds {
  id          String   @id @default(cuid())
  match       Match    @relation(fields: [matchId], references: [id])
  matchId     String
  provider    String
  market      String
  outcome     String
  price       Float
  probability Float?
  evPlus      Float?
  timestamp   DateTime @default(now())

  @@index([matchId])
}
